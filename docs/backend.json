
{
  "entities": {
    "Client": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Client",
      "type": "object",
      "description": "Represents a client of BoldNet Digital.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "object", "properties": { "en": { "type": "string" }, "fr": { "type": "string" } } },
        "logoUrl": { "type": "string", "format": "uri" },
        "websiteUrl": { "type": "string", "format": "uri" },
        "order": { "type": "number" }
      },
      "required": ["id", "name", "logoUrl"]
    },
    "StyledImage": {
      "title": "StyledImage",
      "type": "object",
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "zoom": { "type": "number", "default": 1 },
        "x": { "type": "number", "default": 0 },
        "y": { "type": "number", "default": 0 },
        "layoutScale": { "type": "number", "default": 1, "description": "Taille de l'élément sur la page" },
        "layoutX": { "type": "number", "default": 0, "description": "Déplacement horizontal sur la page" },
        "layoutY": { "type": "number", "default": 0, "description": "Déplacement vertical sur la page" }
      }
    },
    "PersonalBrandingPage": {
      "title": "PersonalBrandingPage",
      "type": "object",
      "properties": {
        "hero": {
          "type": "object",
          "properties": {
            "backgroundImageUrl": { "oneOf": [{ "type": "string" }, { "$ref": "#/entities/StyledImage" }] },
            "title": { "type": "string" },
            "subtitle": { "type": "string" }
          }
        }
      }
    },
    "UgcOfferPage": {
      "title": "UgcOfferPage",
      "type": "object",
      "properties": {
        "hero": {
          "type": "object",
          "properties": {
            "backgroundImageUrl": { "oneOf": [{ "type": "string" }, { "$ref": "#/entities/StyledImage" }] }
          }
        }
      }
    }
  }
}
